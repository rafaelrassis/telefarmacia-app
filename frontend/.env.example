# Copie para .env e preencha com valores reais. Nunca commitar .env.

# URL do backend
VITE_API_URL="http://localhost:3000"

# Client ID do Google OAuth (mesmo valor configurado no backend)
VITE_GOOGLE_CLIENT_ID=""

# Versão dos termos de uso exibida ao paciente (mesmo valor de
# TERMOS_TELEFARMACIA_VERSAO no backend)
VITE_TERMOS_TELEFARMACIA_VERSAO="1.0"

# Monitoramento de erros (opcional) — sem VITE_SENTRY_DSN, o Sentry não é
# inicializado (no-op).
VITE_SENTRY_DSN=""
