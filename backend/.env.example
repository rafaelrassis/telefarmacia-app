# Copie para .env e preencha com valores reais. Nunca commitar .env.

# ── Banco de dados ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:senha@localhost:5432/telefarmacia"

# ── Servidor ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Origens permitidas por CORS (separadas por vírgula, sem espaço extra)
FRONTEND_URL="http://localhost:5174"
# Usado em links de e-mail/templates que apontam para a própria API
BACKEND_URL="http://localhost:3000"

# ── Autenticação ──────────────────────────────────────────────────────────
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
GOOGLE_CLIENT_ID=""

# ── Admin ─────────────────────────────────────────────────────────────────
# E-mails com acesso ao painel administrativo (separados por vírgula)
ADMIN_EMAILS=""
# E-mail que recebe notificação de novo cadastro de farmacêutico
ADMIN_NOTIFICATION_EMAIL=""

# ── E-mail (Brevo API) ────────────────────────────────────────────────────
# Envio via API HTTP do Brevo (não SMTP) — hosts como o Render bloqueiam
# conexões SMTP de saída, então o relay SMTP trava com "Connection timeout"
# em produção. Gerar a chave em: Brevo > Configurações de API.
BREVO_API_KEY=""
# Endereço que aparece como remetente para o destinatário — precisa ser um
# e-mail (ou domínio) verificado no Brevo.
SMTP_FROM_EMAIL=""

# ── Web Push (VAPID) ──────────────────────────────────────────────────────
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contato@exemplo.com"

# ── Regras de negócio ─────────────────────────────────────────────────────
PRECO_CONSULTA_PADRAO=50.00
TERMOS_VERSAO="1.0"
TERMOS_TELEFARMACIA_VERSAO="1.0"

# ── Uploads ───────────────────────────────────────────────────────────────
# Diretório de armazenamento de uploads (opcional — default calculado em
# relação ao código-fonte se não configurado)
UPLOAD_DIR=""

# ── Monitoramento de erros (opcional) ────────────────────────────────────
# Sem SENTRY_DSN, o Sentry não é inicializado (no-op).
SENTRY_DSN=""
