# Ambiente de testes — NUNCA aponte para o banco de dev/produção.
# O nome do banco (e a própria DATABASE_URL) precisa conter "test": é checado
# em tests/_guard.js antes de qualquer teste rodar.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/telefarmacia_test"
NODE_ENV=test
JWT_SECRET="test_jwt_secret_nao_usar_em_producao"
ADMIN_EMAILS="admin.teste@telefarmacia.test"
PRECO_CONSULTA_PADRAO=50.00
FRONTEND_URL="http://localhost:5174"
