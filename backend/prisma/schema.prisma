generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PACIENTE
  FARMACEUTICO
}

model User {
  id                          String             @id @default(uuid())
  email                       String             @unique
  name                        String
  role                        UserRole
  googleId                    String?            @unique
  password                    String?
  passwordChangedAt           DateTime?
  emailVerified               DateTime?
  phone                       String?
  photoUrl                    String?
  createdAt                   DateTime           @default(now())
  pharmacistProfile           PharmacistProfile?
  pacienteProfile             PacienteProfile?
  pagamentos                  Pagamento[]        @relation("PacientePagamentos")
  carteira                    Carteira?          @relation("PacienteCarteira")
  availabilities              Availability[]     @relation("PharmacistAvailability")
  weeklySchedule              WeeklySchedule[]   @relation("PharmacistWeeklySchedule")
  avaliacoesComoFarmaceutico   Avaliacao[]         @relation("FarmaceuticoAvaliacoes")
  avaliacoesComoPaciente       Avaliacao[]         @relation("PacienteAvaliacoes")
  filaAgendadaComoPaciente     FilaAgendada[]      @relation("PacienteFilaAgendada")
  filaAgendadaComoFarmaceutico FilaAgendada[]      @relation("FarmaceuticoFilaAgendada")
  filaUrgenteComoPaciente      FilaUrgente[]       @relation("PacienteFilaUrgente")
  filaUrgenteComoFarmaceutico  FilaUrgente[]       @relation("FarmaceuticoFilaUrgente")
  farmaceuticoStatus           FarmaceuticoStatus?
  dependentes                  DependentProfile[]  @relation("TitularDependentes")
  notificacoes                 Notificacao[]       @relation("UserNotificacoes")
  consentRecords               ConsentRecord[]
  bloqueiosAgenda              BloqueioAgenda[] @relation("FarmaceuticoBloqueios")
  templatesOrientacao          TemplateOrientacao[] @relation("FarmaceuticoTemplates")
  repasses                     Repasse[] @relation("FarmaceuticoRepasses")
  adminAudits                  AdminAuditLog[] @relation("AdminAudits")
  pushSubscriptions            PushSubscription[] @relation("UserPushSubs")
  passwordResets               PasswordReset[]
  verificationTokens           VerificationToken[]
  lembretesMedicacao           LembreteMedicacao[] @relation("PacienteLembretesMedicacao")
}

model VerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("UserPushSubs", fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  keys      Json
  createdAt DateTime @default(now())
  @@index([userId])
}

model Notificacao {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("UserNotificacoes", fields: [userId], references: [id], onDelete: Cascade)
  tipo       String
  titulo     String
  mensagem   String
  lida       Boolean  @default(false)
  criadoEm   DateTime @default(now())
  consultaId String?
}

model PacienteProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nomeCompleto         String
  dataNascimento       DateTime
  genero               String
  cpf                  String   @unique
  telefone             String?
  cep                  String?
  logradouro           String?
  numero               String?
  complemento          String?
  bairro               String?
  cidade               String?
  estado               String?
  aceiteTermos         Boolean
  dataAceite           DateTime
  versaoTermos         String
  onboardingConcluido  Boolean  @default(false)
}

model PharmacistProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  crfNumber         String
  crfUF             String
  bio               String
  tags              String[]
  isApproved        Boolean   @default(false)
  isSuspended       Boolean   @default(false)
  isOnline          Boolean   @default(false)
  urlDocIdentidade  String?
  urlDocCrf         String?
  dataEnvioDoc      DateTime?
  precoConsulta        Decimal?  @db.Decimal(10, 2)
  disponivelUrgencias  Boolean   @default(true) @map("disponivel_urgencias")
  chavePix             String?
}

model Pagamento {
  id          String    @id @default(uuid())
  pacienteId  String
  paciente    User      @relation("PacientePagamentos", fields: [pacienteId], references: [id], onDelete: Cascade)
  valor       Decimal   @db.Decimal(10, 2)
  status      String    @default("Pendente")
  qrCodeMock  String
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?
}

model Carteira {
  id         String                @id @default(uuid())
  pacienteId String                @unique
  paciente   User                  @relation("PacienteCarteira", fields: [pacienteId], references: [id], onDelete: Cascade)
  saldo      Decimal               @default(0.00) @db.Decimal(10, 2)
  updatedAt  DateTime              @updatedAt
  transacoes TransacaoCarteira[]
}

model TransacaoCarteira {
  id         String   @id @default(uuid())
  carteiraId String
  carteira   Carteira @relation(fields: [carteiraId], references: [id], onDelete: Cascade)
  tipo       String
  valor      Decimal  @db.Decimal(10, 2)
  saldoApos  Decimal  @db.Decimal(10, 2)
  descricao  String
  consultaId String?
  criadoEm   DateTime @default(now())
}

model WeeklySchedule {
  id           String  @id @default(uuid())
  pharmacistId String
  pharmacist   User    @relation("PharmacistWeeklySchedule", fields: [pharmacistId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startTime    String
  endTime      String
  isActive     Boolean @default(true)
  @@unique([pharmacistId, dayOfWeek])
}

model Avaliacao {
  id             String        @id @default(uuid())
  pacienteId     String
  paciente       User          @relation("PacienteAvaliacoes", fields: [pacienteId], references: [id], onDelete: Cascade)
  pharmacistId   String?
  pharmacist     User?         @relation("FarmaceuticoAvaliacoes", fields: [pharmacistId], references: [id], onDelete: SetNull)
  filaAgendadaId String?       @unique
  filaAgendada   FilaAgendada? @relation(fields: [filaAgendadaId], references: [id], onDelete: Cascade)
  filaUrgenteId  String?       @unique
  filaUrgente    FilaUrgente?  @relation(fields: [filaUrgenteId], references: [id], onDelete: Cascade)
  nota           Int
  comentario     String?
  createdAt      DateTime      @default(now())
}

model Availability {
  id           String   @id @default(uuid())
  pharmacistId String
  pharmacist   User     @relation("PharmacistAvailability", fields: [pharmacistId], references: [id], onDelete: Cascade)
  dateTime     DateTime
  isBooked     Boolean  @default(false)
}

model SystemConfig {
  key   String @id
  value String
}

model SistemaHorario {
  id         String  @id @default(uuid())
  diaSemana  Int     @unique
  horaInicio String
  horaFim    String
  ativo      Boolean @default(true)
}

model FilaAgendada {
  id              String            @id @default(uuid())
  pacienteId      String
  paciente        User              @relation("PacienteFilaAgendada", fields: [pacienteId], references: [id], onDelete: Cascade)
  dataHora        DateTime
  status          String            @default("aguardando")
  farmaceuticoId  String?
  farmaceutico    User?             @relation("FarmaceuticoFilaAgendada", fields: [farmaceuticoId], references: [id])
  creditoDebitado Decimal           @db.Decimal(10, 2)
  criadoEm        DateTime          @default(now())
  aceitoEm        DateTime?
  dependentId     String?
  dependent       DependentProfile? @relation("DependenteFilaAgendada", fields: [dependentId], references: [id])
  avaliacao       Avaliacao?
}

model FilaUrgente {
  id              String            @id @default(uuid())
  pacienteId      String
  paciente        User              @relation("PacienteFilaUrgente", fields: [pacienteId], references: [id], onDelete: Cascade)
  status          String            @default("aguardando")
  farmaceuticoId  String?
  farmaceutico    User?             @relation("FarmaceuticoFilaUrgente", fields: [farmaceuticoId], references: [id])
  creditoDebitado Decimal           @db.Decimal(10, 2)
  criadoEm        DateTime          @default(now())
  aceitoEm        DateTime?
  dependentId     String?
  dependent       DependentProfile? @relation("DependenteFilaUrgente", fields: [dependentId], references: [id])
  avaliacao       Avaliacao?
}

model DependentProfile {
  id                      String         @id @default(uuid())
  ownerId                 String
  owner                   User           @relation("TitularDependentes", fields: [ownerId], references: [id], onDelete: Cascade)
  nome                    String
  dataNascimento          DateTime
  sexo                    String
  parentesco              String?
  ativo                   Boolean        @default(true)
  aceitouResponsabilidade Boolean        @default(false)
  dadosSaude              Json?
  criadoEm                DateTime       @default(now())
  atualizadoEm            DateTime       @updatedAt
  filaAgendada            FilaAgendada[] @relation("DependenteFilaAgendada")
  filaUrgente             FilaUrgente[]  @relation("DependenteFilaUrgente")
  lembretesMedicacao      LembreteMedicacao[] @relation("DependenteLembretesMedicacao")
}

model LembreteMedicacao {
  id              String            @id @default(uuid())
  pacienteId      String
  paciente        User              @relation("PacienteLembretesMedicacao", fields: [pacienteId], references: [id], onDelete: Cascade)
  dependentId     String?
  dependent       DependentProfile? @relation("DependenteLembretesMedicacao", fields: [dependentId], references: [id], onDelete: Cascade)
  medicamento     String
  dose            String?
  horarios        String[]
  ativo           Boolean           @default(true)
  ultimoDisparoEm DateTime?
  criadoEm        DateTime          @default(now())

  @@index([pacienteId])
}

model FarmaceuticoStatus {
  farmaceuticoId String   @id
  farmaceutico   User     @relation(fields: [farmaceuticoId], references: [id], onDelete: Cascade)
  online         Boolean  @default(false)
  ultimoPing     DateTime @default(now())
}

model PartnerPharmacy {
  id            String           @id @default(cuid())
  nome          String
  logoUrl       String?
  baseUrl       String
  affiliateCode String
  linkTemplate  String?
  ativo         Boolean          @default(true)
  ordem         Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  clicks        AffiliateClick[]
}

model AffiliateClick {
  id         String          @id @default(cuid())
  pharmacyId String
  pharmacy   PartnerPharmacy @relation(fields: [pharmacyId], references: [id], onDelete: Cascade)
  consultaId String?
  createdAt  DateTime        @default(now())
}

model TemplateOrientacao {
  id           String   @id @default(uuid())
  pharmacistId String
  pharmacist   User     @relation("FarmaceuticoTemplates", fields: [pharmacistId], references: [id], onDelete: Cascade)
  titulo       String
  conteudo     String   @db.Text
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model BloqueioAgenda {
  id           String   @id @default(uuid())
  pharmacistId String
  pharmacist   User     @relation("FarmaceuticoBloqueios", fields: [pharmacistId], references: [id], onDelete: Cascade)
  dataInicio   DateTime
  dataFim      DateTime
  motivo       String?
  criadoEm     DateTime @default(now())
}

model Repasse {
  id                   String        @id @default(uuid())
  pharmacistId         String
  pharmacist           User          @relation("FarmaceuticoRepasses", fields: [pharmacistId], references: [id], onDelete: Restrict)
  adminId              String
  referenciaTransacao  String?
  valorTotal           Decimal       @db.Decimal(10, 2)
  periodoInicio        DateTime
  periodoFim           DateTime
  criadoEm             DateTime      @default(now())
  itens                RepasseItem[]
}

model RepasseItem {
  id           String   @id @default(uuid())
  repasseId    String
  repasse      Repasse  @relation(fields: [repasseId], references: [id], onDelete: Cascade)
  consultaId   String
  consultaTipo String
  valorBruto   Decimal  @db.Decimal(10, 2)
  percentual   Decimal  @db.Decimal(5, 2)
  valorLiquido Decimal  @db.Decimal(10, 2)

  @@unique([consultaId, consultaTipo])
}

model ConviteFarmaceutico {
  id        String   @id @default(uuid())
  email     String
  nome      String
  token     String   @unique
  usado     Boolean  @default(false)
  expiresAt DateTime
  criadoEm  DateTime @default(now())
  adminId   String
}

model AdminAuditLog {
  id        String   @id @default(uuid())
  adminId   String
  admin     User     @relation("AdminAudits", fields: [adminId], references: [id])
  acao      String
  alvoTipo  String?
  alvoId    String?
  detalhes  Json?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([alvoTipo, alvoId])
}

model ConsentRecord {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipoTermo   String
  versaoTermo String
  aceitoEm    DateTime @default(now())
  ip          String?

  @@unique([userId, tipoTermo, versaoTermo])
  @@index([userId, tipoTermo])
}
